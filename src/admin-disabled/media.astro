---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Media Library | ByJDG CMS">
  <main class="admin-main">
    <div class="admin-top">
      <div>
        <p class="eyebrow">CMS Library</p>
        <h1>Media Library</h1>
      </div>

      <a class="preview" href="/">Preview Site →</a>
    </div>

    <section class="panel">
      <div class="panel-top">
        <div>
          <h2>Images</h2>
          <p>Browse, upload, copy, and delete images from your public images folder.</p>
        </div>

        <div class="actions">
          <button class="secondary" id="uploadImageBtn" type="button">
            Upload Image
          </button>

          <button class="publish" id="loadImagesBtn" type="button">
            Load Images
          </button>

          <input id="imageUpload" type="file" accept="image/*" hidden />
        </div>
      </div>

      <div class="image-library" id="imageLibrary"></div>
    </section>
  </main>
</AdminLayout>

<script>
  const loadImagesButton = document.getElementById("loadImagesBtn");
  const uploadImageButton = document.getElementById("uploadImageBtn");
  const imageUpload = document.getElementById("imageUpload");
  const imageLibrary = document.getElementById("imageLibrary");

  async function loadImages() {
    const response = await fetch("/api/list-images.json");
    const result = await response.json();

    imageLibrary.innerHTML = "";

    result.images.forEach((imagePath) => {
      const card = document.createElement("article");
      card.className = "image-card";

      card.innerHTML = `
        <img src="${imagePath}" alt="">
        <div class="image-card-body">
          <span>${imagePath}</span>

          <button class="copy-image" type="button" data-path="${imagePath}">
            Copy Path
          </button>

          <button class="delete-image" type="button" data-path="${imagePath}">
            Delete Image
          </button>
        </div>
      `;

      const copyButton = card.querySelector(".copy-image");
      const deleteButton = card.querySelector(".delete-image");

      copyButton?.addEventListener("click", async () => {
        await navigator.clipboard.writeText(imagePath);
        copyButton.textContent = "Copied";
      });

      deleteButton?.addEventListener("click", async () => {
        const confirmed = confirm(`Delete ${imagePath}?`);

        if (!confirmed) return;

        const response = await fetch("/api/delete-image.json", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ imagePath }),
        });

        const result = await response.json();

        if (result.success) {
          await loadImages();
        } else {
          alert(result.error || "Could not delete image.");
        }
      });

      imageLibrary.appendChild(card);
    });
  }

  loadImagesButton?.addEventListener("click", loadImages);

  uploadImageButton?.addEventListener("click", () => {
    imageUpload?.click();
  });

  imageUpload?.addEventListener("change", async () => {
    const file = imageUpload.files?.[0];

    if (!file) return;

    const formData = new FormData();
    formData.append("image", file);

    const response = await fetch("/api/upload-image.json", {
      method: "POST",
      body: formData,
    });

    const result = await response.json();

    if (result.success) {
      imageUpload.value = "";
      await loadImages();
      alert("Image uploaded.");
    } else {
      alert(result.error || "Image upload failed.");
    }
  });

  loadImages();
</script>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  .admin-main {
    min-width: 0;
  }

  .admin-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin-bottom: 28px;
  }

  .eyebrow {
    color: #b7b0a7;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-size: 0.7rem;
    margin-bottom: 8px;
  }

  h1 {
    font-family: Georgia, serif;
    font-size: 2.8rem;
    margin: 0;
  }

  .panel {
    width: 100%;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.035);
    padding: 24px;
    border-radius: 14px;
    overflow: hidden;
  }

  .panel-top {
    display: flex;
    justify-content: space-between;
    gap: 22px;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .panel h2 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin: 0 0 10px;
  }

  .panel p {
    color: #b7b0a7;
    margin: 0;
  }

  .actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .publish,
  .preview,
  .secondary {
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.05);
    color: #f5f1ea;
    cursor: pointer;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.72rem;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
  }

  .publish,
  .secondary {
    padding: 14px 18px;
  }

  .publish {
    background: #d6b36a;
    color: #050505;
    border-color: #d6b36a;
  }

  .secondary {
    background: rgba(255,255,255,0.05);
    color: #f5f1ea;
  }

  .preview {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 20px;
    min-width: 150px;
  }

  .image-library {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  :global(.image-card) {
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
  }

  :global(.image-card img) {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }

  :global(.image-card-body) {
    padding: 12px;
    display: grid;
    gap: 10px;
  }

  :global(.image-card span) {
    color: #b7b0a7;
    font-size: 0.72rem;
    word-break: break-all;
  }

  :global(.image-card button) {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    cursor: pointer;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.68rem;
  }

  :global(.copy-image) {
    border: 1px solid rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.05);
    color: #f5f1ea;
  }

  :global(.delete-image) {
    border: 1px solid rgba(220,70,70,0.35);
    background: rgba(220,70,70,0.15);
    color: #ff8b8b;
  }

  @media (max-width: 1100px) {
    .image-library {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .image-library {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .admin-top,
    .panel-top {
      flex-direction: column;
      align-items: flex-start;
    }

    .actions {
      width: 100%;
      flex-direction: column;
    }

    .publish,
    .secondary {
      width: 100%;
    }
  }

  @media (max-width: 650px) {
    .image-library {
      grid-template-columns: 1fr;
    }
  }
</style>