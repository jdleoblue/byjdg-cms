---
const { episode } = Astro.props;
---

<article class="film-card">
  <img src={episode.image} alt={episode.title} />

  <div class="film-overlay"></div>

  <div class="film-content">
    <div class="episode">{episode.episode}</div>
    <h3>{episode.title}</h3>
    <p>{episode.description}</p>

    <a
      class="watch-link"
      href={episode.youtube || `/projects/${episode.slug}`}
      target={episode.youtube ? "_blank" : "_self"}
      rel={episode.youtube ? "noopener" : ""}
    >
      Watch Film →
    </a>
  </div>
</article>

<style>
  .film-card {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.045);
  }

  .film-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.74;
    transform: scale(1.02);
    transition: transform 0.6s ease, opacity 0.6s ease;
  }

  .film-card:hover img {
    transform: scale(1.08);
    opacity: 0.9;
  }

  .film-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.9),
      rgba(0,0,0,0.26),
      rgba(0,0,0,0.08)
    );
    z-index: 1;
  }

  .film-content {
    position: absolute;
    left: 26px;
    right: 26px;
    bottom: 26px;
    z-index: 2;
  }

  .episode {
    font-size: 0.68rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #b7b0a7;
    margin-bottom: 8px;
  }

  h3 {
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 400;
    font-size: 1.65rem;
    line-height: 1.1;
    margin-bottom: 10px;
    color: #f5f1ea;
  }

  p {
    color: #b7b0a7;
    font-size: 0.92rem;
    max-width: 330px;
    margin-bottom: 24px;
  }

  .watch-link {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    text-decoration: none;
    color: #f5f1ea;
  }

  @media (max-width: 650px) {
    .film-card {
      height: 340px;
    }
  }
</style>