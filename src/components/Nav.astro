---
const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="nav-inner">
    <button class="mobile-menu-button" aria-label="Open menu">
      <span class="menu-icon"></span>
    </button>

    <a href="/" class="logo">ByJDG</a>

    <nav class="nav-links">
      <a class={currentPath === "/" ? "active" : ""} href="/">Home</a>

      <a href="https://www.youtube.com/@by-jdg" target="_blank" rel="noopener">
        YouTube
      </a>

      <a class={currentPath === "/about" ? "active" : ""} href="/about">
        About
      </a>

      <a class={currentPath.startsWith("/projects") ? "active" : ""} href="/projects">
        Projects
      </a>
    </nav>
  </div>
</header>

<div class="nav-overlay"></div>

<script>
  const menuButton = document.querySelector(".mobile-menu-button");
  const overlay = document.querySelector(".nav-overlay");
  const links = document.querySelectorAll(".nav-links a");

  menuButton?.addEventListener("click", () => {
    document.body.classList.toggle("menu-open");
  });

  overlay?.addEventListener("click", () => {
    document.body.classList.remove("menu-open");
  });

  links.forEach((link) => {
    link.addEventListener("click", () => {
      document.body.classList.remove("menu-open");
    });
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 120;

    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nav-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;

    display: flex;
    align-items: center;
    justify-content: space-between;

    padding: 28px 40px;
    box-sizing: border-box;
  }

  .logo {
    color: #f5f1ea;
    text-decoration: none;
    font-family: Georgia, serif;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(18px, 2vw, 34px);
    min-width: 0;
  }

  .nav-links a {
    position: relative;
    color: #f5f1ea;
    text-decoration: none;
    font-size: clamp(0.58rem, 0.75vw, 0.72rem);
    letter-spacing: clamp(0.18em, 0.28vw, 0.34em);
    text-transform: uppercase;
    opacity: 0.82;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .nav-links a:hover,
  .nav-links a.active {
    opacity: 1;
  }

  .nav-links a.active::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;

    width: 100%;
    height: 1px;

    background: rgba(245,241,234,0.8);
  }

  .mobile-menu-button,
  .nav-overlay {
    display: none;
  }

  .menu-icon::before {
    content: "☰";
  }

  :global(body.menu-open) .menu-icon::before {
    content: "×";
  }

  @media (max-width: 760px) {
    .nav {
      height: 92px;
      background: rgba(0,0,0,0.72);
    }

    .nav-inner {
      height: 92px;
      padding: 0 6vw;
      justify-content: center;
    }

    .logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      font-size: 2rem;
    }

    .mobile-menu-button {
      display: block;
      position: absolute;
      left: 6vw;
      top: 50%;
      transform: translateY(-50%);
      z-index: 999;

      background: transparent;
      border: 0;
      color: #f5f1ea;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
    }

    .nav-links {
      position: fixed;
      top: 0;
      left: 0;
      width: 58%;
      max-width: 330px;
      height: 100vh;

      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 26px;

      padding: 110px 38px 40px;

      background: rgba(0,0,0,0.92);
      backdrop-filter: blur(18px);
      border-right: 1px solid rgba(255,255,255,0.12);

      opacity: 0;
      visibility: hidden;
      transform: translateX(-100%);
      transition: transform 0.35s ease, opacity 0.25s ease;

      z-index: 150;
    }

    :global(body.menu-open) .nav-links {
      transform: translateX(0);
      opacity: 1;
      visibility: visible;
    }

    .nav-links a {
      font-size: 0.72rem;
      letter-spacing: 0.32em;
    }

    .nav-links a.active::after {
      bottom: -7px;
    }

    .nav-overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.15);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      z-index: 100;
    }

    :global(body.menu-open) .nav-overlay {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }
</style>