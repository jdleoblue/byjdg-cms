---
import AdminLayout from "../layouts/AdminLayout.astro";

export const prerender = false;

const episodeFiles = import.meta.glob("../content/episodes/*.json", {
  eager: true,
});

const episodes = Object.values(episodeFiles).map((file) => file.default);

const selectedSlug = Astro.url.searchParams.get("episode")?.trim();

const currentEpisode =
  episodes.find((episode) => episode.slug?.trim() === selectedSlug) ||
  episodes[0];
---

<AdminLayout title="ByJDG CMS">
  <main class="admin-main">
    <div class="admin-top">
      <div>
        <p class="eyebrow">Content Studio</p>
        <h1>Edit Episode</h1>
      </div>

      <a class="preview" href="/">Preview Site →</a>
    </div>

    <div class="episode-actions">
      <div class="episode-tabs">
        {episodes.map((episode) => (
          <a
            class:list={[
              "episode-tab",
              episode.slug === currentEpisode.slug && "selected",
            ]}
            href={`/admin/?episode=${episode.slug}`}
          >
            <span>{episode.episode}</span>
            <strong>{episode.title}</strong>
          </a>
        ))}
      </div>

      <a class="new-episode" href="/admin/new">
        + New Episode
      </a>
    </div>

    <div class="admin-grid">
      <section class="panel editor">
        <h2>Episode Details</h2>

        <label>
          Episode
          <input id="episode" value={currentEpisode.episode} />
        </label>

        <label>
          Title
          <input id="title" value={currentEpisode.title} />
        </label>

        <label>
          Slug
          <input id="slug" value={currentEpisode.slug} readonly />
        </label>

        <label>
          Description
          <textarea id="description">{currentEpisode.description}</textarea>
        </label>

        <label>
          YouTube Link
          <input id="youtube" value={currentEpisode.youtube} />
        </label>

        <label>
          Image Path
          <input id="image" value={currentEpisode.image} />
        </label>

        <label>
          Content
          <textarea id="content" class="large">{currentEpisode.content}</textarea>
        </label>
      </section>

      <aside class="side-panels">
        <section class="panel">
          <h2>Publish</h2>

          <div class="status">{currentEpisode.status}</div>

          <button class="publish" id="updateEpisodeBtn" type="button">
            Update Episode
          </button>

          <button
            class="delete"
            id="deleteEpisodeBtn"
            data-slug={currentEpisode.slug}
            type="button"
          >
            Delete Episode
          </button>

          <a class="link-button secondary" href={`/projects/${currentEpisode.slug}`}>
            Preview Episode
          </a>
        </section>

        <section class="panel">
          <h2>Featured Image</h2>

          <img
            class="image-preview"
            src={currentEpisode.image}
            alt={currentEpisode.title}
          />

          <input id="imageUpload" type="file" accept="image/*" hidden />

          <button class="secondary" id="changeImageBtn" type="button">
            Upload New Image
          </button>

          <button class="secondary" id="selectExistingImageBtn" type="button">
            Select From Library
          </button>

          <div class="image-library" id="imageLibrary"></div>
        </section>

        <section class="panel">
          <h2>SEO</h2>

          <label>
            Meta Title
            <input id="metaTitle" value={currentEpisode.metaTitle} />
          </label>

          <label>
            Meta Description
            <textarea id="metaDescription">{currentEpisode.metaDescription}</textarea>
          </label>
        </section>
      </aside>
    </div>
  </main>
</AdminLayout>

<script>
  const updateButton = document.getElementById("updateEpisodeBtn");
  const deleteButton = document.getElementById("deleteEpisodeBtn");

  const changeImageButton = document.getElementById("changeImageBtn");
  const selectExistingImageButton = document.getElementById("selectExistingImageBtn");
  const imageUpload = document.getElementById("imageUpload");
  const imageInput = document.getElementById("image");
  const imagePreview = document.querySelector(".image-preview");
  const imageLibrary = document.getElementById("imageLibrary");

  updateButton?.addEventListener("click", async () => {
    const data = {
      episode: document.getElementById("episode")?.value,
      title: document.getElementById("title")?.value,
      slug: document.getElementById("slug")?.value,
      description: document.getElementById("description")?.value,
      youtube: document.getElementById("youtube")?.value,
      image: document.getElementById("image")?.value,
      content: document.getElementById("content")?.value,
      metaTitle: document.getElementById("metaTitle")?.value,
      metaDescription: document.getElementById("metaDescription")?.value,
      status: "Published",
    };

    const response = await fetch("/api/update-episode.json", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(data),
    });

    const result = await response.json();

    if (result.success) {
      alert("Episode updated.");
      window.location.href = `/admin/?episode=${result.slug}`;
    } else {
      alert(result.error || "Could not update episode.");
    }
  });

  deleteButton?.addEventListener("click", async () => {
    const slug = deleteButton.dataset.slug;

    if (!slug) return;

    const confirmed = confirm(`Delete episode "${slug}"?`);

    if (!confirmed) return;

    const response = await fetch("/api/delete-episode.json", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ slug }),
    });

    const result = await response.json();

    if (result.success) {
      window.location.href = "/admin";
    } else {
      alert(result.error || "Could not delete episode.");
    }
  });

  changeImageButton?.addEventListener("click", () => {
    imageUpload?.click();
  });

  imageUpload?.addEventListener("change", async () => {
    const file = imageUpload.files?.[0];

    if (!file) return;

    const formData = new FormData();
    formData.append("image", file);

    const response = await fetch("/api/upload-image.json", {
      method: "POST",
      body: formData,
    });

    const result = await response.json();

    if (result.success) {
      imageInput.value = result.imagePath;
      imagePreview.src = result.imagePath;
      imageUpload.value = "";
      alert("Image uploaded. Click Update Episode to save it.");
    } else {
      alert(result.error || "Image upload failed.");
    }
  });

  selectExistingImageButton?.addEventListener("click", async () => {
    const response = await fetch("/api/list-images.json");
    const result = await response.json();

    imageLibrary.innerHTML = "";

    result.images.forEach((imagePath) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "image-option";

      button.innerHTML = `
        <img src="${imagePath}" alt="">
        <span>${imagePath}</span>
      `;

      button.addEventListener("click", () => {
        imageInput.value = imagePath;
        imagePreview.src = imagePath;
        imageLibrary.innerHTML = "";
      });

      imageLibrary.appendChild(button);
    });
  });
</script>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  .admin-main {
    min-width: 0;
  }

  .admin-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    margin-bottom: 28px;
  }

  .eyebrow {
    color: #b7b0a7;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-size: 0.7rem;
    margin-bottom: 8px;
  }

  h1 {
    font-family: Georgia, serif;
    font-size: 2.8rem;
    margin: 0;
  }

  .episode-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin: 22px 0 28px;
  }

  .episode-tabs {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    flex: 1;
  }

  .new-episode {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    padding: 15px 18px;
    border-radius: 12px;
    background: #d6b36a;
    border: 1px solid #d6b36a;
    color: #050505 !important;
    text-decoration: none !important;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 700;
    min-height: 50px;
  }

  .new-episode:visited {
    color: #050505 !important;
  }

  .new-episode:hover {
    opacity: 0.9;
  }

  .episode-tab {
    display: grid;
    gap: 5px;
    min-width: 190px;
    padding: 14px 16px;
    border-radius: 12px;
    color: #f5f1ea;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.035);
  }

  .episode-tab:hover {
    background: rgba(255,255,255,0.07);
  }

  .episode-tab.selected {
    background: rgba(214,179,106,0.12);
    border-color: rgba(214,179,106,0.35);
  }

  .episode-tab:visited {
    color: #f5f1ea;
  }

  .episode-tab span {
    color: #b7b0a7;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .episode-tab strong {
    color: #f5f1ea;
    font-family: Georgia, serif;
    font-size: 1rem;
  }

  .admin-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 22px;
    align-items: start;
  }

  .panel {
    width: 100%;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.035);
    padding: 24px;
    border-radius: 14px;
    overflow: hidden;
  }

  .panel h2 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: 22px;
  }

  .editor,
  .side-panels {
    display: grid;
    gap: 18px;
  }

  label {
    display: grid;
    gap: 8px;
    color: #b7b0a7;
    font-size: 0.85rem;
  }

  input,
  textarea {
    width: 100%;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.12);
    color: #f5f1ea;
    padding: 14px;
    font: inherit;
    border-radius: 8px;
  }

  textarea {
    min-height: 110px;
    resize: vertical;
  }

  textarea.large {
    min-height: 210px;
  }

  button,
  .link-button,
  .preview {
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.05);
    color: #f5f1ea;
    cursor: pointer;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.72rem;
    text-align: center;
    text-decoration: none;
  }

  button,
  .link-button {
    width: 100%;
    display: block;
    padding: 14px 18px;
  }

  .publish {
    background: #d6b36a;
    color: #050505;
    border-color: #d6b36a;
    margin-bottom: 10px;
  }

  .delete {
    width: 100%;
    margin-top: 10px;
    background: rgba(220, 70, 70, 0.15);
    border: 1px solid rgba(220, 70, 70, 0.4);
    color: #ff8b8b;
  }

  .preview {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 20px;
    min-width: 150px;
  }

  .secondary {
    margin-top: 10px;
  }

  .status {
    color: #78d99a;
    margin-bottom: 18px;
  }

  .image-preview {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 14px;
  }

  .image-library {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 16px;
    max-height: 420px;
    overflow-y: auto;
  }

  :global(.image-option) {
    padding: 0;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #f5f1ea;
    cursor: pointer;
    text-align: left;
  }

  :global(.image-option img) {
    width: 100%;
    height: 130px;
    object-fit: cover;
    display: block;
  }

  :global(.image-option span) {
    display: block;
    padding: 8px;
    font-size: 0.68rem;
    color: #b7b0a7;
    word-break: break-all;
  }

  @media (max-width: 900px) {
    .admin-grid {
      grid-template-columns: 1fr;
    }

    .admin-top {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>