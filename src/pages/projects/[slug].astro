---
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const episodeFiles = import.meta.glob(
    "../../content/episodes/*.json",
    { eager: true }
  );

  const episodes = Object.values(episodeFiles).map(
    (file) => file.default
  );

  return episodes.map((episode) => ({
    params: {
      slug: episode.slug
    },
    props: {
      episode
    }
  }));
}

const { episode } = Astro.props;
---

<BaseLayout>
  <section class="project">
    <img src={episode.image} alt={episode.title} />

    <div class="content">
      <div class="eyebrow">Episode</div>

      <h1>{episode.title}</h1>

      <p>{episode.description}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .project {
    padding-top: 140px;
  }

  img {
    width: 100%;
    max-height: 700px;
    object-fit: cover;
    display: block;
  }

  .content {
    padding: 80px 7vw;
  }

  h1 {
    font-size: 5rem;
    font-family: Georgia, serif;
    margin-bottom: 20px;
  }

  p {
    max-width: 700px;
    color: #b7b0a7;
    line-height: 1.7;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #b7b0a7;
    margin-bottom: 18px;
  }

  @media (max-width: 768px) {
    .content {
      padding: 50px 6vw;
    }

    h1 {
      font-size: 3rem;
    }
  }
</style>